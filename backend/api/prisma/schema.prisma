generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== ДАРКСТОРЫ ====================

model Darkstore {
  id        String   @id @default(cuid())
  name      String
  shortName String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories         Category[]
  promotions         Promotion[]
  orders             Order[]
  purchases          Purchase[]
  deliveryZones      DeliveryZone[]
  couriers           Courier[]
  carts              Cart[]
  staff              AdminUserDarkstore[]
  darkstoreProducts  DarkstoreProduct[]
}

// Связь many-to-many: один AdminUser может работать в нескольких дарксторах
model AdminUserDarkstore {
  id          String    @id @default(cuid())
  adminUserId String
  darkstoreId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  darkstore   Darkstore @relation(fields: [darkstoreId], references: [id], onDelete: Cascade)

  @@unique([adminUserId, darkstoreId])
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String
  description String?
  sort        Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  imageUrl    String?
  
  // Торговая наценка по умолчанию для товаров этой категории (%)
  markupPercent Float  @default(0)
  
  // Поддержка подкатегорий (иерархическая структура)
  parentId    String?
  parent      Category?  @relation("CategoryToSubcategory", fields: [parentId], references: [id], onDelete: Cascade)
  subcategories Category[] @relation("CategoryToSubcategory")
  
  // Даркстор
  darkstoreId String
  darkstore   Darkstore @relation(fields: [darkstoreId], references: [id], onDelete: Cascade)
  
  products  Product[]
  productsAsSubcategory Product[] @relation("ProductSubcategory")
  darkstoreProducts DarkstoreProduct[]
  darkstoreProductsAsSubcategory DarkstoreProduct[] @relation("DarkstoreProductSubcategory")

  @@unique([slug, darkstoreId])
}

model Product {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  imageUrl    String?
  weight      String?
  barcode     String?
  isActive    Boolean  @default(true)

  // Глобальная категория по умолчанию (используется при создании DarkstoreProduct)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  
  subcategoryId String?
  subcategory   Category? @relation("ProductSubcategory", fields: [subcategoryId], references: [id], onDelete: SetNull)
  
  cartItems          CartItem[]
  orderItems         OrderItem[]
  favorites          Favorite[]
  batches            Batch[]
  darkstoreProducts  DarkstoreProduct[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Привязка товара к даркстору: цены, остатки, ячейка, категория — всё per-darkstore
model DarkstoreProduct {
  id            String   @id @default(cuid())
  
  productId     String
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  darkstoreId   String
  darkstore     Darkstore @relation(fields: [darkstoreId], references: [id], onDelete: Cascade)
  
  // Ценообразование (из партий)
  price         Int      @default(0)  // Цена продажи (целые рубли)
  oldPrice      Int?     // Старая цена для отображения скидки
  purchasePrice Int?     // Закупочная цена последней партии
  
  // Складские данные
  stock         Int      @default(0)  // Остатки на этом складе
  cellNumber    String?  // Номер ячейки хранения
  maxPerOrder   Int      @default(10) // Максимум штук в одном заказе (0 = без лимита)
  
  // Категория в этом дарксторе (может отличаться)
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  
  subcategoryId String?
  subcategory   Category? @relation("DarkstoreProductSubcategory", fields: [subcategoryId], references: [id], onDelete: SetNull)
  
  isActive      Boolean  @default(true)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([productId, darkstoreId])
}

model Promotion {
  id        String   @id @default(cuid())
  title     String
  imageUrl  String
  url       String?
  sort      Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Даркстор
  darkstoreId String
  darkstore   Darkstore @relation(fields: [darkstoreId], references: [id], onDelete: Cascade)
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("admin") // superadmin | admin | manager
  name         String?  // ФИО
  phone        String?  // Номер телефона
  permissions  String?  // JSON: разрешённые разделы для менеджера, например ["orders","products"]
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  darkstores   AdminUserDarkstore[]
}

model Cart {
  id        String     @id @default(cuid())
  token     String     @unique
  status    CartStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Даркстор (опционален — корзина создаётся до выбора н.п.)
  darkstoreId String?
  darkstore   Darkstore? @relation(fields: [darkstoreId], references: [id], onDelete: SetNull)

  items     CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  qty       Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([cartId, productId])
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
}

model Order {
  id           String      @id @default(cuid())
  orderNumber  Int         @unique @default(autoincrement())
  status       OrderStatus @default(NEW)

  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Restrict)

  cartId       String?
  cartToken    String?

  customerName  String
  phone         String
  addressLine   String
  comment       String?
  totalAmount   Int      // Сумма за товары (целые рубли)
  deliveryFee   Int      @default(0)  // Стоимость доставки (целые рубли)
  
  // Экономика заказа
  purchaseCost  Int      @default(0)  // Себестоимость товаров (закупочная цена)
  courierCost   Int      @default(0)  // Расходы на курьера (тариф зоны доставки)
  profit        Int      @default(0)  // Прибыль = totalAmount - purchaseCost - courierCost
  settlement    String?              // Населённый пункт заказа
  
  // Геопозиция клиента (добавляется менеджером из чата)
  customerLatitude  Float?
  customerLongitude Float?
  
  // Курьер
  courierId    String?
  courier      Courier?    @relation(fields: [courierId], references: [id], onDelete: SetNull)
  
  // Даркстор
  darkstoreId  String
  darkstore    Darkstore   @relation(fields: [darkstoreId], references: [id], onDelete: Cascade)
  
  // Информация об отмене
  canceledBy   CanceledBy?
  cancelReason String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items        OrderItem[]
  statusHistory OrderStatusHistory[]
  chatMessages  ChatMessage[]
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  title     String
  price     Int
  qty       Int
  amount    Int
  
  // Связь с партией для FIFO
  batchId   String?
  batchCode String?  // Код партии формата "24 00001 18"
  batch     Batch?   @relation(fields: [batchId], references: [id], onDelete: SetNull)

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

enum OrderStatus {
  NEW
  CONFIRMED
  ASSEMBLING
  ASSIGNED_TO_COURIER
  ACCEPTED_BY_COURIER
  ON_THE_WAY
  DELIVERED
  CANCELED
}

// Кем отменен заказ
enum CanceledBy {
  CLIENT
  COURIER
  MANAGER
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  comment   String?
  changedBy String?     // Логин админа, изменившего статус
  createdAt DateTime    @default(now())

  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
}


// ==================== ЗОНЫ ДОСТАВКИ ====================

model DeliveryZone {
  id               String   @id @default(cuid())
  settlement       String   @unique           // Код населённого пункта (произвольный)
  settlementTitle  String   @default("")      // Название населённого пункта для отображения
  deliveryFee      Int      @default(150)      // Тариф за доставку (целые рубли) — начисляется курьеру
  freeDeliveryFrom Int      @default(1500)     // Бесплатная доставка от суммы (целые рубли)
  isActive         Boolean  @default(true)     // Включена ли доставка в этот н.п.
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  // Даркстор
  darkstoreId String
  darkstore   Darkstore @relation(fields: [darkstoreId], references: [id], onDelete: Cascade)
}

model User {
  id           String   @id @default(cuid())
  login        String   @unique
  passwordHash String
  settlement   String   // Код населённого пункта
  name         String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  email        String   @unique
  phone         String
  addressLine   String
  pushSubscription String?  // JSON подписки для Web Push
  orders       Order[]
  favorites    Favorite[]
  kopilkas     Kopilka[]
}

// ==================== ЧАТ ПО ЗАКАЗАМ ====================

enum ChatSender {
  MANAGER
  CLIENT
}

model ChatMessage {
  id        String     @id @default(cuid())
  orderId   String
  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sender    ChatSender
  text      String?
  imageUrl  String?    // Путь к загруженному изображению
  latitude  Float?     // Геопозиция
  longitude Float?     // Геопозиция
  isRead    Boolean    @default(false)
  createdAt DateTime   @default(now())

  @@index([orderId, createdAt])
}

// ==================== ЗАКУПКИ И ПАРТИИ ====================

model Purchase {
  id              String   @id @default(cuid())
  purchaseNumber  Int      @unique @default(autoincrement()) // Номер закупки (00001)
  supplierName    String?  // Поставщик
  notes           String?  // Примечания
  totalAmount     Int      @default(0) // Общая сумма закупки
  
  // Даркстор
  darkstoreId String
  darkstore   Darkstore @relation(fields: [darkstoreId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  batches         Batch[]
}

model Batch {
  id              String      @id @default(cuid())
  batchCode       String      @unique // Код партии: "24 00001 18"
  
  productId       String
  product         Product     @relation(fields: [productId], references: [id], onDelete: Restrict)
  
  purchaseId      String
  purchase        Purchase    @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  
  quantity        Int         // Закупленное количество
  remainingQty    Int         // Оставшееся количество
  purchasePrice   Int         // Закупочная цена за единицу (целые рубли)
  markupPercent   Float       @default(0)  // Торговая наценка (%)
  sellingPrice    Int         @default(0)  // Цена продажи = purchasePrice * (1 + markup/100) (целые рубли)
  discountPercent Float       @default(0)  // Скидка за истекающий срок годности (%)
  
  expiryDate      DateTime?   // Срок годности
  cellNumber      String      // Номер ячейки хранения
  
  status          BatchStatus @default(ACTIVE)
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  orderItems      OrderItem[]
  writeOffs       WriteOff[]
}

enum BatchStatus {
  ACTIVE      // Активная партия
  EXPIRED     // Просрочена
  SOLD_OUT    // Распродана
  WRITTEN_OFF // Списана
}

model WriteOff {
  id          String   @id @default(cuid())
  batchId     String
  batch       Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  
  quantity    Int      // Количество списанного товара
  reason      String   // Причина списания (просрочка, брак, и т.д.)
  
  createdAt   DateTime @default(now())
}

// ==================== КУРЬЕРЫ ====================

// Статус курьера
enum CourierStatus {
  OFF_DUTY        // Не работаю - курьер недоступен для заказов
  AVAILABLE       // Свободен - менеджер может отправлять заказы
  ACCEPTED        // Взял заказ(ы) - ожидает ещё или готовится к выезду
  DELIVERING      // Везу заказы - недоступен для новых заказов
}

model Courier {
  id            String        @id @default(cuid())
  fullName      String        // ФИО курьера
  login         String        @unique // Логин для входа
  passwordHash  String        // Хеш пароля
  phone         String        // Номер телефона
  
  carBrand      String?       // Марка автомобиля (необязательно)
  carNumber     String?       // Номер автомобиля (необязательно)
  
  // deliveryRate removed - теперь тариф зависит от зоны доставки
  
  isActive      Boolean       @default(true) // Активен или нет
  status        CourierStatus @default(AVAILABLE) // Текущий статус курьера
  
  // Push-уведомления
  pushSubscription  String?   // JSON подписки для Web Push
  
  // Даркстор
  darkstoreId   String
  darkstore     Darkstore     @relation(fields: [darkstoreId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  orders        Order[]       // Заказы курьера
}

// ==================== КОПИЛКА (Savings Groups) ====================

model Kopilka {
  id          String   @id @default(cuid())
  shareId     String   @unique @default(cuid())
  name        String
  goalAmount  Int
  startMonth  String   // "2025-11" format
  userId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User?           @relation(fields: [userId], references: [id])
  members KopilkaMember[]
}

model KopilkaMember {
  id        String @id @default(cuid())
  kopilkaId String
  name      String

  kopilka       Kopilka              @relation(fields: [kopilkaId], references: [id], onDelete: Cascade)
  contributions KopilkaContribution[]
}

model KopilkaContribution {
  id         String @id @default(cuid())
  memberId   String
  amount     Int
  paidMonths String @default("[]") // JSON array: ["2025-11","2025-12"]

  member KopilkaMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

// ==================== НАСТРОЙКИ ДОСТАВКИ ====================

// DeliverySettings removed — replaced by DeliveryZone per settlement


